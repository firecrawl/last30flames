# Copy to .env and fill in. Bun loads .env automatically - no dotenv needed.
# Everything here is OPTIONAL. The skill runs with no keys at all (the Firecrawl
# CLI uses a keyless free tier). These only raise limits when present.

# Optional: higher Firecrawl limits + concurrency. Without it, the keyless
# free tier is used (rate-limited).
FIRECRAWL_API_KEY=

# Optional: only raises GitHub's API rate limit.
GITHUB_TOKEN=
